# Drop-in overrides for linuxserver/openssh-server's generated sshd_config
# (loaded from /config/sshd/sshd_config.d/, which the entrypoint wires up via
# an Include directive when that directory exists).

# Verbose logging so file uploads are visible via `docker compose logs sftp`
# - useful when demoing the watcher reacting to a new file.
LogLevel VERBOSE

# Modest brute-force friction for the demo-only password account.
MaxAuthTries 3
