# Copy to .env and adjust as needed. All values below are the defaults
# baked into infra/docker-compose.yml - this file just makes them visible
# and overridable in one place. Local/dev only - not real secrets.

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
QUEUE_NAME=orders.inbound
DLQ_NAME=orders.inbound.dlq

# MinIO (S3 emulator)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=wms-orders-processed
S3_REGION=us-east-1

# fake-gcs (GCS emulator)
GCS_BUCKET=wms-orders-processed
GOOGLE_CLOUD_PROJECT=demo-project

# SFTP (demo-only credentials for the local emulator - not a real secret)
SFTP_PASSWORD=demopass

# Worker behaviour
UPLOAD_MAX_CONCURRENCY=2
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_BASE=2
LOG_LEVEL=INFO

# Used to derive idempotency keys (HMAC) - change for any non-local deployment
CORRELATION_SECRET=dev-secret-change-me
